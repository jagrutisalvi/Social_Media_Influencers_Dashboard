    <worksheet name='Scatter Plot'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontname='Cambria' fontsize='11'>Influencer Performance: Followers vs Engagement</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='SocialMediaData (social_media_influence_project_dataset)' name='federated.0ehdqgw0so4j5j1ef9gm70odp7o4' />
          </datasources>
          <datasource-dependencies datasource='federated.0ehdqgw0so4j5j1ef9gm70odp7o4'>
            <column caption='Avg Comments' datatype='integer' name='[Avg_Comments]' role='measure' type='quantitative' />
            <column caption='Avg Likes' datatype='integer' name='[Avg_Likes]' role='measure' type='quantitative' />
            <column caption='Average Engagement Rate' datatype='real' name='[Calculation_1222989306953729]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Avg_Likes]+[Avg_Comments]+[Avg_Likes])/SUM([Followers])' />
            </column>
            <column caption='Influencer Category' datatype='string' name='[Calculation_1273290547265537]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Followers] &gt;= 1000000 THEN &quot;Top Influencers&quot;&#13;&#10;ELSEIF [Followers] &gt;= 100000 THEN &quot;Established Creators&quot;&#13;&#10;ELSEIF [Followers] &gt;= 10000 THEN &quot;Growing Creators&quot;&#13;&#10;ELSE &quot;Small Creators&quot;&#13;&#10;END' />
            </column>
            <column caption='Estimated Earnings' datatype='integer' name='[Estimated_Earnings]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Followers]' role='measure' type='quantitative' />
            <column caption='Influencer Name' datatype='string' name='[Influencer_Name]' role='dimension' type='nominal' />
            <column datatype='string' name='[Platform]' role='dimension' type='nominal' />
