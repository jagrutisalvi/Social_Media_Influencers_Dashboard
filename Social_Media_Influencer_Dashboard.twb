      <column caption='Audience Age Group' datatype='string' name='[Audience_Age_Group]' role='dimension' type='nominal' />
      <column caption='Audience Gender' datatype='string' name='[Audience_Gender]' role='dimension' type='nominal' />
      <column caption='Avg Comments' datatype='integer' name='[Avg_Comments]' role='measure' type='quantitative' />
      <column caption='Avg Likes' datatype='integer' name='[Avg_Likes]' role='measure' type='quantitative' />
      <column caption='Avg Shares' datatype='integer' name='[Avg_Shares]' role='measure' type='quantitative' />
      <column caption='Brand Collaborations' datatype='integer' name='[Brand_Collaborations]' role='measure' type='quantitative' />
      <column caption='Total Influencers' datatype='integer' name='[Calculation_0254868244615169]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Influencer_ID])' />
      </column>
      <column caption='Total Followers' datatype='integer' name='[Calculation_0254868244783106]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Followers])' />
      </column>
      <column caption='Avg Engagement' datatype='real' name='[Calculation_0254868245073923]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Engagement_Rate])' />
      </column>
      <column caption='Total Earnings' datatype='integer' name='[Calculation_0254868245454852]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Estimated_Earnings])' />
      </column>
      <column caption='Total Collaborations' datatype='integer' name='[Calculation_0254868245602309]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Brand_Collaborations])' />
      </column>
      <column caption='Average Engagement Rate' datatype='real' name='[Calculation_1222989306953729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Avg_Likes]+[Avg_Comments]+[Avg_Likes])/SUM([Followers])' />
      </column>
      <column caption='Influencer Category' datatype='string' name='[Calculation_1273290547265537]' role='dimension' type='nominal'>
